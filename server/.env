# ═══════════════════════════════════════════════════════════
#  server/.env — Environment Variables
#  ⚠️  NEVER commit this file to git. Add it to .gitignore.
# ═══════════════════════════════════════════════════════════

PORT=5000

# REQUIRED: Change this to a long random string before running.
# You can generate one with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_STRING_AT_LEAST_64_CHARS